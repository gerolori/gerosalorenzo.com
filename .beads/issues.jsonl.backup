{"id":"bd-editorial","title":"Enable editorial workflow","description":"Add publish_mode: editorial_workflow to config.yml.","status":"open","priority":2,"type":"task","dependencies":[{"target":"bd-phase5epic","type":"blocks"}],"created_at":"2026-03-04T10:22:00Z","updated_at":"2026-03-04T10:22:00Z"}
{"id":"bd-workflowtest","title":"Test workflow states","description":"Test all states: create draft (cms/blog/post-slug branch), move to In Review (creates PR), move to Ready, publish (merges PR, deletes branch).","status":"open","priority":2,"type":"task","dependencies":[{"target":"bd-editorial","type":"blocks"}],"created_at":"2026-03-04T10:23:00Z","updated_at":"2026-03-04T10:23:00Z"}
{"id":"bd-previewlinks","title":"Configure deploy preview links","description":"Optional. Set up Cloudflare Pages deploy previews. Add preview_context if needed. Test preview links in workflow UI.","status":"open","priority":3,"type":"task","dependencies":[{"target":"bd-workflowtest","type":"blocks"}],"created_at":"2026-03-04T10:24:00Z","updated_at":"2026-03-04T10:24:00Z"}
