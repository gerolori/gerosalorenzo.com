{"id":"bd-localcms","title":"Test CMS interface locally","description":"Access CMS at /admin. Verify authentication flow works. Check all collections visible. Test create/edit/delete.","status":"open","priority":1,"type":"task","dependencies":[{"target":"bd-phase6epic","type":"blocks"}],"created_at":"2026-03-04T10:26:00Z","updated_at":"2026-03-04T10:26:00Z"}
{"id":"bd-contenttest","title":"Test content creation and editing","description":"Create blog post with all fields. Upload and embed images. Verify preview renders. Save and check frontmatter.","status":"open","priority":1,"type":"task","dependencies":[{"target":"bd-localcms","type":"blocks"}],"created_at":"2026-03-04T10:27:00Z","updated_at":"2026-03-04T10:27:00Z"}
