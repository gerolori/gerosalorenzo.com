{{- $.Scratch.Add "index" slice -}}
{{- range site.RegularPages -}}
    {{- if and (not .Params.searchHidden) (ne .Layout `archives`) (ne .Layout `search`) }}
    {{- $currentPage := . -}}
    {{- $categories := slice -}}
    {{- with .Params.categories -}}
        {{- range . -}}
            {{- $categories = $categories | append (dict "name" . "slug" (. | urlize)) -}}
        {{- end -}}
    {{- end -}}
    {{- $series := slice -}}
    {{- with .Params.series -}}
        {{- range . -}}
            {{- $seriesPage := index site.Taxonomies.series . -}}
            {{- with $seriesPage -}}
                {{- $seriesTotal := .Page.Params.series_total | default (len .Pages) -}}
                {{- $series = $series | append (dict 
                    "name" .Page.Title 
                    "permalink" .Page.Permalink 
                    "part" ($currentPage.Params.series_weight | default "?")
                    "total" $seriesTotal
                ) -}}
            {{- end -}}
        {{- end -}}
    {{- end -}}
    {{- $.Scratch.Add "index" (dict 
        "title" .Title 
        "content" .Plain 
        "permalink" .Permalink 
        "summary" .Summary
        "date" (.Date.Format "2006-01-02")
        "readingTime" .ReadingTime
        "categories" $categories
        "series" $series
    ) -}}
    {{- end }}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
